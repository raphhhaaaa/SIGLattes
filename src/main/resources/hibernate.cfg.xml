<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>

        <!--
            ============================================================
            OTIMIZAÇÕES DB2: BATCH INSERT/UPDATE
            ============================================================
            jdbc.batch_size = 50: agrupa 50 INSERTs/UPDATEs em um único
            round-trip ao banco. Reduz drasticamente o tempo de salvar
            um curriculo com muitas producoes.

            order_inserts / order_updates = true: reordena as operações
            pendentes por tipo de entidade, maximizando o aproveitamento
            do batch. Sem isso, cada entidade diferente "quebra" o batch.

            batch_versioned_data = true: necessário para que o batch
            funcione corretamente com entidades versionadas no DB2.
        -->
        <property name="hibernate.jdbc.batch_size">50</property>
        <property name="hibernate.order_inserts">true</property>
        <property name="hibernate.order_updates">true</property>
        <property name="hibernate.jdbc.batch_versioned_data">true</property>

        <!--
            ============================================================
            POOL DE CONEXÕES C3P0
            ============================================================
            Valores ajustados para DB2 em Docker local:
            - max_size aumentado de 20 para 30 para suportar as 30 threads
              do ExtratorVM sem contenção no pool.
            - timeout reduzido para 120s (DB2 fecha conexões ociosas mais
              rápido que MySQL por padrão).
            - idle_test_period = 600s: testa conexões a cada 10 minutos
              para evitar "stale connection" típico do DB2 em Docker.
            - preferredTestQuery específico para DB2 (mais leve que SELECT 1).
        -->
        <property name="hibernate.connection.provider_class">org.hibernate.c3p0.internal.C3P0ConnectionProvider</property>
        <property name="hibernate.c3p0.min_size">3</property>
        <property name="hibernate.c3p0.max_size">30</property>
        <property name="hibernate.c3p0.timeout">120</property>
        <property name="hibernate.c3p0.max_statements">50</property>
        <property name="hibernate.c3p0.idle_test_period">600</property>
        <property name="hibernate.c3p0.testConnectionOnCheckout">false</property>
        <property name="hibernate.c3p0.testConnectionOnCheckin">true</property>
        <property name="hibernate.c3p0.preferredTestQuery">SELECT 1 FROM SYSIBM.SYSDUMMY1</property>

        <!--        <property name="connection.driver_class">com.mysql.cj.jdbc.Driver</property>-->
        <!--        <property name="connection.url">jdbc:mysql://localhost:3306/LATTESEXTRATOR?useTimezone=true&amp;serverTimezone=UTC&amp;allowPublicKeyRetrieval=true&amp;useSSL=false</property>-->
        <!--        <property name="connection.username">root</property>-->
        <!--        <property name="connection.password">1973</property>-->
        <!--        <property name="dialect">org.hibernate.dialect.MySQL8Dialect</property>-->                <!-- CONEXÃO MYSQL DB -->


        <!-- Conexão IBM DB2 -->
        <property name="hibernate.connection.driver_class">com.ibm.db2.jcc.DB2Driver</property>
        <property name="hibernate.connection.url">jdbc:db2://localhost:50000/lattes</property>
        <property name="hibernate.connection.username">db2inst1</property>
        <property name="hibernate.connection.password">1973</property>
        <property name="hibernate.dialect">org.hibernate.dialect.DB2Dialect</property>

        <!--
            OTIMIZAÇÃO DB2: use_sql_comments = false em produção reduz
            overhead de geração de comentários SQL no log.
            Mude para true apenas para debug de queries.
        -->
        <property name="hibernate.hbm2ddl.auto">update</property>
        <property name="show_sql">false</property>
        <property name="format_sql">false</property>
        <property name="use_sql_comments">false</property>

        <!--
            OTIMIZAÇÃO DB2: jdbc.fetch_size controla quantas linhas o
            driver DB2 busca por round-trip ao iterar um ResultSet.
            O padrão do driver DB2 é 1, o que causa N viagens de rede
            para N linhas. Valor 100 reduz significativamente o tempo
            de queries que retornam muitas linhas (ex: listarTodos).
        -->
        <property name="hibernate.jdbc.fetch_size">100</property>

        <mapping class="com.uem.extrator.model.Curriculo"/>
        <mapping class="com.uem.extrator.model.Formacao"/>
        <mapping class="com.uem.extrator.model.Producao"/>
        <mapping class="com.uem.extrator.model.Instituicao"/>
        <mapping class="com.uem.extrator.model.Curso"/>
        <mapping class="com.uem.extrator.model.Atuacao"/>
        <mapping class="com.uem.extrator.model.Vinculo"/>
        <mapping class="com.uem.extrator.model.Atividade"/>
        <mapping class="com.uem.extrator.model.AtividadeItem"/>
        <mapping class="com.uem.extrator.model.Usuario"/>
        <mapping class="com.uem.extrator.model.LogAuditoria"/>
        <mapping class="com.uem.extrator.model.Qualis"/>

    </session-factory>
</hibernate-configuration>
